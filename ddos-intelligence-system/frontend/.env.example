# WebSocket URL for the backend attack stream
# In development: leave unset to auto-derive from window.location via Vite proxy
# In Docker/production: set to the actual backend WebSocket URL
# VITE_WS_URL=wss://your-backend.onrender.com/ws/attacks

# REST API base URL for the backend
# In development: leave unset to use Vite proxy (relative paths)
# In production: set to the actual backend URL (no trailing slash)
# VITE_API_URL=https://your-backend.onrender.com
